# Carregado pelo react-scripts durante `yarn build` (produção).
# O plugin de ESLint embutido no CRA envia opções removidas no ESLint 9 (que o
# Yarn 4 resolve), quebrando o build. O lint é feito à parte por `yarn lint`
# (flat config), então desligamos o plugin inline aqui.
DISABLE_ESLINT_PLUGIN=true
